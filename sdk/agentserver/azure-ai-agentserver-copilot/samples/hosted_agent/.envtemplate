# Azure AI Foundry BYOK mode (Managed Identity)
# Set AZURE_AI_FOUNDRY_RESOURCE_URL to activate BYOK.
# Authentication uses DefaultAzureCredential (Managed Identity, Azure CLI, etc.)
# AZURE_AI_FOUNDRY_RESOURCE_URL=https://<your-resource>.openai.azure.com

# Optional: override the default model deployment name
# COPILOT_MODEL=gpt-4.1
